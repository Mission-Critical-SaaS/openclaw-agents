SLACK_ALLOW_FROM=["U082DEF37PC","U081YTU8JCX","U0ADABVCVH8","U05PJJS5XST","U07LD2KVA58","U07EW4CD78C","U08FP393H4J","U084XE4S43G","U08NGTS8Y5B","U0AKF614URE","U0AJLT30KMG","U0AJEGUSELB","U0AM170694Z","U0ALRTLF752","U0ALERF7F9V"]

