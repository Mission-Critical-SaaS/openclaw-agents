# ──────────────────────────────────────────────────────────
# OpenClaw Multi-Agent Gateway — Environment Variables
# Copy to .env and fill in your actual values
# ──────────────────────────────────────────────────────────

# Anthropic API Key (shared across all agents)
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# ─── Scout (Customer Support Agent) ───
SLACK_BOT_TOKEN_SCOUT=xoxb-SCOUT-BOT-TOKEN
SLACK_APP_TOKEN_SCOUT=xapp-SCOUT-APP-TOKEN

# ─── Trak (Jira / Project Management Agent) ───
SLACK_BOT_TOKEN_TRAK=xoxb-TRAK-BOT-TOKEN
SLACK_APP_TOKEN_TRAK=xapp-TRAK-APP-TOKEN

# ─── Kit (Engineering / Dev Agent) ───
SLACK_BOT_TOKEN_KIT=xoxb-KIT-BOT-TOKEN
SLACK_APP_TOKEN_KIT=xapp-KIT-APP-TOKEN

# ─── MCP Tool Tokens (optional — enable as needed) ───
# JIRA_API_TOKEN=your-jira-api-token
# JIRA_BASE_URL=https://your-org.atlassian.net
# JIRA_USER_EMAIL=you@example.com
# GITHUB_TOKEN=ghp_your-github-token
# STRIPE_API_KEY=sk_live_your-stripe-key
