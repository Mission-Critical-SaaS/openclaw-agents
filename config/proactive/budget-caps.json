{
  "version": 1,
  "description": "Per-agent budget caps for proactive operations. Agents read this at runtime from .budget-caps.json in their workspace.",
  "caps": {
    "kit": {
      "daily": {
        "github_api_calls": 100,
        "slack_messages": 30,
        "jira_updates": 15,
        "auto_fix_prs": 3
      },
      "monthly": {
        "github_api_calls": 2000,
        "slack_messages": 600,
        "jira_updates": 300,
        "auto_fix_prs": 30
      },
      "per_action": {
        "max_files_per_pr_review": 25,
        "max_comments_per_review": 15,
        "max_auto_fix_prs_per_run": 3
      }
    },
    "trak": {
      "daily": {
        "jira_api_calls": 150,
        "slack_messages": 40,
        "notion_updates": 20,
        "enrichments": 100
      },
      "monthly": {
        "jira_api_calls": 3000,
        "slack_messages": 800,
        "notion_updates": 400,
        "enrichments": 2000
      },
      "per_action": {
        "max_issues_per_bulk_update": 10,
        "max_sprint_reports_per_day": 2,
        "max_enrichments_per_run": 10
      }
    },
    "scout": {
      "daily": {
        "zendesk_api_calls": 200,
        "slack_messages": 50,
        "notion_updates": 10,
        "ticket_enrichments": 150
      },
      "monthly": {
        "zendesk_api_calls": 4000,
        "slack_messages": 1000,
        "notion_updates": 200,
        "ticket_enrichments": 3000
      },
      "per_action": {
        "max_tickets_per_summary": 50,
        "max_auto_responses_per_day": 0,
        "max_enrichments_per_run": 15
      }
    },
    "scribe": {
      "daily": {
        "notion_api_calls": 50,
        "slack_messages": 20,
        "confluence_updates": 10,
        "jira_tasks_created": 5
      },
      "monthly": {
        "notion_api_calls": 1000,
        "slack_messages": 400,
        "confluence_updates": 200,
        "jira_tasks_created": 20
      },
      "per_action": {
        "max_pages_per_batch": 5,
        "max_knowledge_articles_per_day": 3,
        "max_gap_tasks_per_run": 10
      }
    },
    "probe": {
      "daily": {
        "browser_sessions": 10,
        "slack_messages": 20,
        "jira_updates": 15,
        "screenshots": 50
      },
      "monthly": {
        "browser_sessions": 200,
        "slack_messages": 400,
        "jira_updates": 300,
        "screenshots": 1000
      },
      "per_action": {
        "max_pages_per_smoke_test": 10,
        "max_screenshots_per_session": 20,
        "max_bug_tickets_per_day": 5
      }
    }
  },
  "enforcement": "advisory",
  "notes": "Caps are advisory — agents track counts in KNOWLEDGE.md and self-limit. Phase 3 tasks (enrichment, auto-fix) have higher caps to support frequent scheduling."
}
