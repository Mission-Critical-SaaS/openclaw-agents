{
  "version": 1,
  "description": "RBAC tier definitions for OpenClaw agent access control. Injected into each agent's workspace at deploy time as .user-tiers.json.",
  "tiers": {
    "admin": {
      "description": "Full access \u2014 org owners, lead devs",
      "permissions": [
        "read",
        "write",
        "delete",
        "deploy",
        "admin",
        "bulk-operations"
      ]
    },
    "developer": {
      "description": "Standard dev access \u2014 code, tickets, deploys",
      "permissions": [
        "read",
        "write",
        "deploy"
      ]
    },
    "support": {
      "description": "Support team \u2014 read-heavy, limited writes",
      "permissions": [
        "read",
        "write-tickets",
        "write-comments"
      ]
    },
    "agent": {
      "description": "Sibling agents (Kit, Trak, Scout, Scribe, Probe, Chief) \u2014 cross-agent dispatch only",
      "permissions": [
        "read",
        "write",
        "cross-agent-dispatch"
      ]
    }
  },
  "default_tier": "support",
  "tier_lookup": {
    "U082DEF37PC": "admin",
    "U081YTU8JCX": "admin",
